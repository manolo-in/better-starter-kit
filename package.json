{
	"name": "better-t3-stack",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"auth-cli": "bunx @better-auth/cli generate --config ./server/auth/cli.ts",
		"auth:generate": "bun run auth-cli --output ./server/db/schema/auth.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"server:build": "bun build ./server/index.ts --outfile ./dist/server.js",
		"server:dev": "bun run --hot --port 4000 ./server/index.ts",
		"server:start": "bun run dist/server.js",
		"server:wrangler": "wrangler dev --config=dev.wrangler.jsonc --port=4000 --test-scheduled",
		"server:open": "bun run server:wrangler --ip=0.0.0.0",
		"web:build": "next build",
		"web:dev": "next dev --turbopack --port=3000",
		"web:lint": "next lint",
		"web:start": "next start",
		"email:copy": "cp .env ./node_modules/@react-email/preview-server/",
		"email:dev": "bun run email:copy && email dev --dir ./server/email --port 7000",
		"email:build": "email export --out ./email/out --pretty --dir ./server/email",
		"format": "biome format ./ --write",
		"build": "bun run web:build"
	},
	"dependencies": {
		"@cloudflare/workers-types": "^4.20251008.0",
		"@libsql/client": "^0.14.0",
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.9",
		"@orpc/client": "^1.9.3",
		"@orpc/server": "^1.9.3",
		"@orpc/tanstack-query": "^1.9.3",
		"@react-email/components": "^1.0.12",
		"@t3-oss/env-nextjs": "^0.13.8",
		"@tanstack/react-form": "^1.23.6",
		"@tanstack/react-query": "^5.90.2",
		"@uidotdev/usehooks": "^2.4.1",
		"better-auth": "^1.6.18",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.38.4",
		"hono": "^4.9.10",
		"kuron": "^0.0.3",
		"lucide-react": "^0.487.0",
		"next": "15.3.0",
		"next-themes": "^0.4.6",
		"nodemailer": "^8.0.11",
		"nuqs": "^2.8.9",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.3.1",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.3.27",
		"@biomejs/biome": "2.5.0",
		"@react-email/preview-server": "^5.2.10",
		"@svgr/webpack": "^8.1.0",
		"@tailwindcss/postcss": "^4.1.14",
		"@types/bun": "^1.2.23",
		"@types/mdx": "^2.0.14",
		"@types/node": "^20.19.19",
		"@types/nodemailer": "^8.0.1",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.1",
		"drizzle-kit": "^0.30.6",
		"react-email": "^6.6.0",
		"shadcn": "^4.11.0",
		"tailwindcss": "^4.1.14",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.9.3",
		"wrangler": "^4.42.1"
	}
}
